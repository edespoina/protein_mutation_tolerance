import os
import numpy as np
from Bio.PDB import PDBParser

# Helper function
def get_CA_coords(chain):
    """
    Extract CA atoms from a Bio.PDB chain.
    """
    ca_atoms = [atom for atom in chain.get_atoms() if atom.get_name() == "CA"]
    return ca_atoms

# Parameters
native_file = "pdb6e6o.ent"       # native structure
mutant_folder = "./mutants/"       # folder containing mutant PDBs
mutation_levels = [5,10,15,20,25,30,40]
seeds = [3,4,6]

parser = PDBParser(QUIET=True)

# Load native structure
native_structure = parser.get_structure("native", native_file)
native_chain = next(native_structure.get_chains())
native_ca_atoms = get_CA_coords(native_chain)
n_atoms = len(native_ca_atoms)
print(f"Native sequence length: {n_atoms} residues")

# Loop over mutants
results = {}

for level in mutation_levels:
    results[level] = {}
    for seed in seeds:
        mutant_file = os.path.join(mutant_folder, f"mutant_{level:02d}_seed{seed}_1.pdb")
        if not os.path.exists(mutant_file):
            print(f"File {mutant_file} not found. Skipping.")
            continue
        
        mutant_structure = parser.get_structure(f"mutant_{level}_{seed}", mutant_file)
        mutant_chain = next(mutant_structure.get_chains())
        mutant_ca_atoms = get_CA_coords(mutant_chain)
        
        if len(mutant_ca_atoms) != n_atoms:
            print(f"WARNING: different number of CA atoms in {mutant_file}. Skipping.")
            continue
        
        # Compute mean pLDDT from B-factor column
        plddt_values = [atom.get_bfactor() for atom in mutant_ca_atoms]
        mean_plddt = np.mean(plddt_values)
        
        results[level][seed] = mean_plddt
        print(f"Level {level}%, Seed {seed} → mean pLDDT = {mean_plddt:.1f}")

# Summary table
print("\nSummary Table: mean pLDDT")
header = "Level%\t" + "\t".join([f"Seed{seed}" for seed in seeds])
print(header)

for level in mutation_levels:
    row = "\t".join([f"{results[level][seed]:.1f}" if seed in results[level] else "-" for seed in seeds])
    print(f"{level}%\t{row}")

